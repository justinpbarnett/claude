{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "model": "haiku",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/validate-commit.sh",
            "timeout": 10,
            "statusMessage": "Validating commit message..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-format.sh",
            "timeout": 30,
            "statusMessage": "Auto-formatting..."
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/check-emdash.sh",
            "timeout": 5,
            "statusMessage": "Checking for emdashes..."
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/post-edit-lint.sh",
            "timeout": 30,
            "statusMessage": "Linting..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/track-commits.sh",
            "timeout": 10,
            "statusMessage": "Tracking commit..."
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/post-commit-check.sh",
            "timeout": 120,
            "statusMessage": "Running post-commit checks..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "github@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "high"
}
